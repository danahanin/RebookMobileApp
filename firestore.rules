rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    match /books/{bookId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid
        || requestAllowedForBook(resource.data, request.resource.data)
      );

      match /chats/{buyerId} {
        allow read: if request.auth != null && chatParticipantAllowed(bookId, buyerId);
        allow create, update: if request.auth != null && chatParticipantAllowed(bookId, buyerId);

        match /messages/{messageId} {
          allow read: if request.auth != null && chatParticipantAllowed(bookId, buyerId);
          allow create: if request.auth != null
            && chatParticipantAllowed(bookId, buyerId)
            && request.resource.data.senderId == request.auth.uid
            && request.resource.data.keys().hasAll(['senderId', 'text', 'createdAt']);
        }
      }
    }
  }
}

function bookOwnerUid(bookId) {
  return get(/databases/$(database)/documents/books/$(bookId)).data.ownerId;
}

function chatParticipantAllowed(bookId, buyerId) {
  return request.auth.uid == buyerId
    || bookOwnerUid(bookId) == request.auth.uid;
}

function requestAllowedForBook(before, after) {
  return before.ownerId == after.ownerId
    && before.title == after.title
    && before.author == after.author
    && before.description == after.description
    && before.imageUrl == after.imageUrl
    && before.createdAt == after.createdAt
    && (
      (before.status == 'AVAILABLE'
        && after.status == 'REQUESTED'
        && after.requestedById == request.auth.uid)
      || (before.status == 'REQUESTED'
        && before.requestedById == request.auth.uid
        && after.status == 'AVAILABLE'
        && after.requestedById == null)
    );
}
